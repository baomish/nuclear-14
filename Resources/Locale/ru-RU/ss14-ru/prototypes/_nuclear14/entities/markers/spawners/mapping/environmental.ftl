<#-- маркер радиации -->
ent-MarkerRadiation1 = маркер радиации (1)
    .suffix = Интенсивность 1
    .desc = Создает в клетке область, постепенно вводящее радиацию в организм живого существа. Значение интенсивности указано в скобках (ед/с, реальное значение зависит от расстояния игрока от центра маркера).
ent-MarkerRadiation2 = маркер радиации (2)
    .desc = { ent-MarkerRadiation1.desc }
ent-MarkerRadiation3 = маркер радиации (3)
    .desc = { ent-MarkerRadiation1.desc }
ent-MarkerRadiation4 = маркер радиации (4)
    .desc = { ent-MarkerRadiation1.desc }
ent-MarkerRadiation5 = маркер радиации (5)
    .desc = { ent-MarkerRadiation1.desc }
ent-MarkerRadiation10 = маркер радиации (10)
    .desc = { ent-MarkerRadiation1.desc }

<#-- невидимая стена -->
ent-MarkerBlocker = невидимая стена
    .desc = Создает в клетке непроходимую прозрачную преграду.

<#-- маркер замедления -->
ent-N14SlowdownTile = маркер замедления
    .desc = Создает в клетке зону, замедляющую скорость передвижения.
